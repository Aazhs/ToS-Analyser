{
  "manifest_version": 3,
  "name": "AI ToS Analyzer",
  "description": "Detects Terms/Privacy popups and summarizes risk using ToS;DR + AI.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI ToS Analyzer"
  }
}
