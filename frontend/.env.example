# Copy this file to .env and fill in your values

# Backend FastAPI base URL
VITE_API_BASE=http://localhost:8000

# GitHub URL where extension setup instructions live
VITE_EXTENSION_INSTRUCTIONS_URL=https://github.com/Aazhs/ToS-Analyser/blob/main/README.md

# Supabase project URL and anon/public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Create this table in Supabase:
# analysis_history
# - id
# - domain
# - result_json
# - created_at
